# Global ENV
BACKEND_PORT=3000
BACKEND_URL=http://localhost:3000
FRONTEND_PORT=5173
FRONTEND_URL=http://localhost:5173

# PostgreSQL
POSTGRES_USER=heirloom
POSTGRES_PASSWORD=changeme
POSTGRES_DB=heirloom
DATABASE_URL=postgresql://heirloom:changeme@localhost:5432/heirloom

# Media uploads
MEDIA_ROOT=./data/media
MAX_UPLOAD_MB=100

# AI assistant (anthropic | openai | ollama | llamacpp)
AI_PROVIDER=openai
AI_MODEL=gpt-5-mini
AI_API_KEY=
AI_BASE_URL=
AI_REASONING_EFFORT=low

# Auth (generate with: openssl rand -hex 32)
AUTH_JWT_SECRET=

# Public site URL for SEO (canonical, Open Graph, sitemap). Set to your domain
# in production; defaults to FRONTEND_URL when unset.
PUBLIC_URL=
