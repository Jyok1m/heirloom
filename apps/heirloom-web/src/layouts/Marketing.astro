---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogTitle?: string;
}

const { title, description, ogTitle } = Astro.props;
const github = import.meta.env.PUBLIC_GITHUB_URL || 'https://github.com/Jyok1m/heirloom';
const origin = (Astro.site ?? new URL(Astro.url.origin)).origin;
const canonical = new URL(Astro.url.pathname, origin).href;
const ogImage = new URL('/og-image.png', origin).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="genealogy, family tree, GEDCOM, self-hosted, open source, ancestry, family history"
    />
    <meta name="author" content="Heirloom" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#faf7f0" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1c1917" media="(prefers-color-scheme: dark)" />
    <link rel="canonical" href={canonical} />

    <!-- Icons & PWA manifest (shared assets with the product app) -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="mask-icon" href="/favicon.svg" color="#d97706" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Heirloom" />
    <meta property="og:title" content={ogTitle ?? title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Heirloom — open source, self-hosted genealogy" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:locale:alternate" content="fr_FR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle ?? title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Heirloom — open source, self-hosted genealogy" />

    <meta name="generator" content={Astro.generator} />

    <!-- Set the theme before paint, sharing Starlight's storage key so the
         choice persists across the marketing pages and the docs. -->
    <script is:inline>
      (() => {
        const stored = localStorage.getItem('starlight-theme');
        const theme =
          stored === 'light' || stored === 'dark'
            ? stored
            : matchMedia('(prefers-color-scheme: dark)').matches
              ? 'dark'
              : 'light';
        document.documentElement.dataset.theme = theme;
      })();
    </script>
  </head>
  <body>
    <header class="nav">
      <div class="wrap nav__inner">
        <a class="brand" href="/" aria-label="Heirloom home">
          <span class="brand__mark">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <g stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 20v-6" />
                <path d="M12 14 12 8" />
                <path d="M12 14 7 11.5" />
                <path d="M12 14 17 11.5" />
                <path d="M12 20l-2.4 2.4M12 20l2.4 2.4" />
              </g>
              <g fill="currentColor">
                <circle cx="12" cy="6.4" r="2.3" />
                <circle cx="6" cy="10.6" r="2.3" />
                <circle cx="18" cy="10.6" r="2.3" />
              </g>
            </svg>
          </span>
          <span class="brand__name">Heirloom</span>
        </a>
        <nav class="nav__links">
          <a href="/#features" class="hide-sm">Features</a>
          <a href="/docs">Docs</a>
          <a href="/demo">Demo</a>
          <a href={github} rel="noopener">GitHub</a>
          <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle color theme">
            <svg class="sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
            <svg class="moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
          </button>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="wrap footer__inner">
        <span>© 2026 Joachim Jasmin · Heirloom is free software (AGPL-3.0).</span>
        <div class="footer__links">
          <a href="/docs">Documentation</a>
          <a href="/demo">Live demo</a>
          <a href={github} rel="noopener">Source code</a>
        </div>
      </div>
    </footer>

    <script is:inline>
      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        const next =
          document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
        document.documentElement.dataset.theme = next;
        localStorage.setItem('starlight-theme', next);
      });
    </script>
  </body>
</html>
