---
import Marketing from '../layouts/Marketing.astro';

const github = import.meta.env.PUBLIC_GITHUB_URL || 'https://github.com/Jyok1m/heirloom';

// Small inline-SVG helpers (no icon dependency). Returned as strings for set:html.
const paths: Record<string, string> = {
  shield: '<path d="M12 3 4 6v6c0 5 3.5 7.5 8 9 4.5-1.5 8-4 8-9V6l-8-3z"/>',
  tree: '<circle cx="12" cy="5" r="2.2"/><circle cx="6" cy="19" r="2.2"/><circle cx="18" cy="19" r="2.2"/><path d="M12 7.2v3.3M12 10.5H6.4a1 1 0 0 0-1 1v5.3M12 10.5h5.6a1 1 0 0 1 1 1v5.3"/>',
  bolt: '<path d="M13 2 4 14h6l-1 8 9-12h-6l1-8z"/>',
  file: '<path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8l-5-5z"/><path d="M14 3v5h5"/>',
  image: '<rect x="3" y="4" width="18" height="16" rx="2"/><circle cx="9" cy="10" r="1.6"/><path d="m4 18 5-5 4 4 3-3 4 4"/>',
  lock: '<rect x="4.5" y="10" width="15" height="10" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/>',
};
const icon = (name: string) =>
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">${paths[name] ?? ''}</svg>`;
const check = () =>
  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>';
const dash = () =>
  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/></svg>';

const features = [
  {
    title: 'Your data, your machine',
    body: 'No proprietary cloud, no lock-in. Heirloom runs on hardware you control — your relatives, photos and stories never leave home.',
    icon: 'shield',
  },
  {
    title: 'A tree that feels alive',
    body: 'A calm, modern canvas with drag-to-arrange cards and a radial fan chart for ancestors. Kinship labels compute automatically.',
    icon: 'tree',
  },
  {
    title: 'Real-time editing',
    body: 'Names, unions, life events and media save as you type. No forms to submit, no page reloads — just build the tree.',
    icon: 'bolt',
  },
  {
    title: 'GEDCOM-friendly model',
    body: 'People, unions, filiations, events and sources are modelled to stay compatible with the genealogy standard for future import/export.',
    icon: 'file',
  },
  {
    title: 'Media & sources',
    body: 'Attach profile photos and documents, and cite your sources, so every fact in the tree can be traced back to where it came from.',
    icon: 'image',
  },
  {
    title: 'Private by design',
    body: 'Share a read-only public view when you want to — contacts, notes and private details are never exposed in a shared link.',
    icon: 'lock',
  },
];
---

<Marketing
  title="Heirloom — Your family history, self-hosted"
  description="Heirloom is a modern, open-source family tree you host yourself. Your relatives, photos and stories live on your own machine — not someone else's cloud."
>
  <!-- Hero -->
  <section class="hero">
    <div class="wrap hero__inner">
      <span class="eyebrow">Open source · Self-hosted</span>
      <h1 class="display">Your family history, on your own terms.</h1>
      <p class="lead">
        Heirloom is a modern, open-source family tree you host yourself. Your
        relatives, photos and stories live on your machine — not someone
        else's cloud.
      </p>
      <div class="hero__cta">
        <a class="btn btn--primary" href="/docs">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          Get started — it's free
        </a>
        <a class="btn btn--ghost" href="/demo">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 5v14l11-7z"/></svg>
          Live demo
        </a>
        <a class="btn btn--ghost" href={github} rel="noopener">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5A11.5 11.5 0 0 0 .5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.37-3.88-1.37-.53-1.34-1.3-1.7-1.3-1.7-1.05-.72.08-.71.08-.71 1.17.08 1.78 1.2 1.78 1.2 1.04 1.78 2.73 1.27 3.4.97.1-.75.4-1.27.73-1.56-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.8 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.24 2.76.12 3.05.74.81 1.18 1.84 1.18 3.1 0 4.43-2.69 5.4-5.25 5.69.41.35.78 1.05.78 2.12v3.14c0 .31.2.67.8.56A11.5 11.5 0 0 0 23.5 12 11.5 11.5 0 0 0 12 .5z"/></svg>
          View source
        </a>
      </div>
      <div class="hero__meta">
        <span set:html={check() + 'AGPL-3.0 licensed'} />
        <span set:html={check() + 'Docker Compose in minutes'} />
        <span set:html={check() + 'PostgreSQL · GraphQL'} />
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="section" id="features">
    <div class="wrap">
      <div class="section__head">
        <h2 class="display">Genealogy that belongs to you</h2>
        <p>Everything you need to build, browse and preserve your family tree — without handing your history to a third party.</p>
      </div>
      <div class="grid">
        {features.map((f) => (
          <article class="card">
            <div class="card__icon" set:html={icon(f.icon)} />
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Install teaser -->
  <section class="section" style="padding-top:0">
    <div class="wrap install">
      <div>
        <div class="section__head" style="text-align:left;margin:0 0 18px">
          <h2 class="display" style="font-size:clamp(1.6rem,3.5vw,2.1rem)">Up and running in three commands</h2>
          <p style="margin-top:12px">Pull the prebuilt images, run the migrations, and you have a private genealogy server behind your reverse proxy. Local development is just as quick.</p>
        </div>
        <a class="btn btn--primary" href="/docs/self-hosting">
          Read the self-hosting guide
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </div>
      <pre class="codeblock"><code><span class="c"># pull the prebuilt images and start the stack</span>
docker compose <span class="p">pull</span>
docker compose run --rm <span class="p">migrate</span>
docker compose up -d <span class="p">api app</span>

<span class="c"># your family tree is now live behind your reverse proxy</span></code></pre>
    </div>
  </section>

  <!-- Hosting options -->
  <section class="section" id="hosting" style="background:var(--surface);border-block:1px solid var(--line)">
    <div class="wrap">
      <div class="section__head">
        <h2 class="display">Free forever, hosted if you want it</h2>
        <p>Heirloom is and stays free and open source. Managed hosting is an optional convenience — never a requirement.</p>
      </div>
      <div class="split">
        <div class="plan plan--featured">
          <span class="plan__tag">Self-hosted</span>
          <h3 class="display">Free</h3>
          <div class="price">Open source · AGPL-3.0 · forever</div>
          <ul>
            <li set:html={check() + 'Full application, no feature gates'} />
            <li set:html={check() + 'Docker Compose or run from source'} />
            <li set:html={check() + 'Your data never leaves your machine'} />
            <li set:html={check() + 'Community support on GitHub'} />
          </ul>
          <a class="btn btn--primary" href="/docs">Get started</a>
        </div>
        <div class="plan">
          <span class="plan__tag">Managed hosting</span>
          <h3 class="display">Coming soon <span class="badge-soon">Soon</span></h3>
          <div class="price">A small monthly plan — we install & run it for you on OVH.</div>
          <ul>
            <li class="muted" set:html={dash() + 'One-click install on a dedicated OVH instance'} />
            <li class="muted" set:html={dash() + 'Backups & updates handled for you'} />
            <li class="muted" set:html={dash() + 'The same open-source app under the hood'} />
          </ul>
          <a class="btn btn--ghost" href={github} rel="noopener">Star the repo to follow along</a>
        </div>
      </div>
    </div>
  </section>
</Marketing>
